&control
  calculation  = 'scf'
  pseudo_dir   = '/home/pintus/Documents/pseudo/SSSP2.0/'
  prefix       = 'SrVO3'
  outdir       = './results/'
 /
 &system
    ibrav         = 1
    celldm(1)     = 7.226
    nat           = 5
    ntyp          = 3
    ecutwfc       = 50
    occupations   = 'smearing'
    smearing      = 'mv'
    degauss       = 0.02
    nbnd          = 50
 /
 &electrons
diagonalization  = 'david'
!electron_maxstep = 1  
!conv_thr         = 1000  
conv_thr 	 = 1.0d-6
diago_thr_init   = 1.0d-13  
!startingpot      = 'file'
!startingwfc	 = 'file'
diago_full_acc   = .true.  
 /
