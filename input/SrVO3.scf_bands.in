&control
  calculation  = 'bands'
  pseudo_dir = '../pseudo/'
  prefix = 'SrVO3'
  outdir = './results/'
 /
 &system
    ibrav = 1
    celldm(1) = 7.226
    nat = 5
    ntyp = 3
    ecutwfc = 100
    occupations = 'smearing'
    smearing = 'mv'
    degauss = 0.02
    nbnd = 50
 /
 &electrons
    diagonalization = 'cg'
    electron_maxstep = 1000
    conv_thr = 1.e-12
 /
